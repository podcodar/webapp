---
import { Icon } from 'astro-icon/components';
import DonationWidget from '@/components/donations/DonationWidget';
import HeroSection from '@/components/ui/HeroSection.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import { LAYOUT_MAIN_FULL_WIDTH, SITE_TITLE } from '@/consts';
import ogDefaultImage from '@/data/og-default';
import { useTranslations } from '@/i18n/utils';
import Layout from '@/layouts/Layout.astro';

const t = useTranslations();
const title = `${t('nav.contributing')} — ${SITE_TITLE}`;
const description = t('contributing.hero.subtitle');
---

<Layout {title} {description} image={ogDefaultImage} mainClass={LAYOUT_MAIN_FULL_WIDTH}>
  <!-- Hero Section -->
  <HeroSection
    eyebrow={t('contributing.hero.eyebrow')}
    title={t('contributing.hero.title')}
    subtitle={t('contributing.hero.subtitle')}
    stats={[
      {
        icon: 'lucide:users',
        value: t('contributing.hero.stats.volunteers.value'),
        label: t('contributing.hero.stats.volunteers.label'),
        color: 'violet',
      },
      {
        icon: 'lucide:folder-code',
        value: t('contributing.hero.stats.projects.value'),
        label: t('contributing.hero.stats.projects.label'),
        color: 'emerald',
      },
      {
        icon: 'lucide:calendar',
        value: t('contributing.hero.stats.years.value'),
        label: t('contributing.hero.stats.years.label'),
        color: 'blue',
      },
    ]}
  >
    <Icon name="lucide:heart" slot="eyebrow-icon" class="w-4 h-4" />
  </HeroSection>

  <!-- Donations Section -->
  <section class="relative py-16 md:py-24 overflow-hidden">
    {/* Background gradients */}
    <div class="absolute inset-0 bg-gradient-to-b from-base-100 via-primary/[0.02] to-base-100 pointer-events-none" />
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-gradient-to-b from-primary/5 to-transparent rounded-full blur-3xl pointer-events-none" />
    <div class="absolute bottom-0 right-0 w-96 h-96 bg-secondary/5 rounded-full blur-3xl pointer-events-none" />

    <div class="relative mx-auto max-w-6xl px-4">
      <SectionHeader
        icon="lucide:gift"
        title={t('contributing.donations.title')}
        subtitle={t('contributing.donations.subtitle')}
        color="primary"
        class="mb-10 md:mb-14"
      />

      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-start">
        {/* Text side — 2/3 width */}
        <div class="flex flex-col justify-center">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-primary/10 text-primary text-xs font-semibold mb-5 w-fit">
            <Icon name="lucide:zap" class="w-3.5 h-3.5" />
            <span>{t('contributing.donations.tagline')}</span>
          </div>

          <h3 class="text-3xl md:text-4xl font-bold mb-5 bg-gradient-to-r from-base-content via-base-content to-base-content/70 bg-clip-text">
            {t('contributing.donations.heading')}
          </h3>

          <p class="text-base-content/75 text-lg leading-relaxed mb-6">
            {t('contributing.donations.body')}
          </p>

          {/* Impact points */}
          <div class="space-y-3 mb-8">
            <div class="flex items-start gap-3">
              <div class="w-6 h-6 rounded-md bg-primary/10 flex items-center justify-center shrink-0 mt-0.5">
                <Icon name="lucide:check" class="w-3.5 h-3.5 text-primary" stroke-width={2.5} />
              </div>
              <span class="text-base-content/70 text-sm">{t('contributing.donations.benefit1')}</span>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-6 h-6 rounded-md bg-primary/10 flex items-center justify-center shrink-0 mt-0.5">
                <Icon name="lucide:check" class="w-3.5 h-3.5 text-primary" stroke-width={2.5} />
              </div>
              <span class="text-base-content/70 text-sm">{t('contributing.donations.benefit2')}</span>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-6 h-6 rounded-md bg-primary/10 flex items-center justify-center shrink-0 mt-0.5">
                <Icon name="lucide:check" class="w-3.5 h-3.5 text-primary" stroke-width={2.5} />
              </div>
              <span class="text-base-content/70 text-sm">{t('contributing.donations.benefit3')}</span>
            </div>
          </div>

          <p class="text-base-content/50 text-sm">
            {t('contributing.donations.cta')}
            {' '}
            <a href="/contact" class="link link-primary font-medium">{t('contributing.donations.contactLink')}</a>.
          </p>
        </div>

        {/* Widget side — 1/3 width */}
        <div class="lg:sticky lg:top-8 lg:col-span-1">
          <DonationWidget client:load />
        </div>
      </div>
    </div>
  </section>

  <!-- Volunteering Section -->
  <section class="py-16 md:py-24 bg-gradient-to-b from-base-200/50 to-base-100 border-y border-base-300/50">
    <div class="mx-auto max-w-6xl px-4">
      <SectionHeader
        icon="lucide:hand-helping"
        title={t('contributing.volunteering.title')}
        subtitle={t('contributing.volunteering.subtitle')}
        color="violet"
        class="mb-8"
      />

      <div class="max-w-3xl">
        <p class="text-base-content/90 m-0 mb-4 text-lg leading-relaxed">
          {t('contributing.volunteering.body.1')}
        </p>
        <p class="text-base-content/90 m-0 mb-6 text-lg leading-relaxed">
          {t('contributing.volunteering.body.2')}
        </p>
        <p class="m-0 flex flex-wrap gap-3">
          <a href="/join-us" class="btn btn-outline btn-primary no-underline">
            {t('contributing.volunteering.cta1')}
          </a>
          <a
            href="https://github.com/podcodar"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-ghost no-underline"
          >
            {t('contributing.volunteering.cta2')}
          </a>
        </p>
      </div>
    </div>
  </section>

  <!-- Partnerships Section -->
  <section class="py-16 md:py-24 bg-base-100">
    <div class="mx-auto max-w-6xl px-4">
      <SectionHeader
        icon="lucide:handshake"
        title={t('contributing.partnerships.title')}
        subtitle={t('contributing.partnerships.subtitle')}
        color="emerald"
        class="mb-8"
      />

      <div class="max-w-3xl">
        <p class="text-base-content/90 m-0 mb-6 text-lg leading-relaxed">
          {t('contributing.partnerships.body')}
        </p>
        <p class="m-0 flex flex-wrap gap-3">
          <a href="/contact" class="btn btn-primary no-underline">{t('contributing.partnerships.cta')}</a>
        </p>
      </div>
    </div>
  </section>
</Layout>
