---
import { Icon } from 'astro-icon/components';
import CallToAction from '@/components/ui/CallToAction.astro';
import ChannelCard from '@/components/ui/ChannelCard.astro';
import HeroSection from '@/components/ui/HeroSection.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import { LAYOUT_MAIN_FULL_WIDTH, SITE_TITLE } from '@/consts';
import {
  aboutCommunity,
  communicationChannels,
  coreValues,
  eventsBlock,
  mission,
  projects,
} from '@/data/marketing';
import ogDefaultImage from '@/data/og-default';
import Layout from '@/layouts/Layout.astro';

const title = `Sobre — ${SITE_TITLE}`;
const description =
  'Missão, valores e como a PodCodar se organiza: núcleo pedagógico, guildas, iniciativas e canais de comunicação.';
---

<Layout {title} {description} image={ogDefaultImage} mainClass={LAYOUT_MAIN_FULL_WIDTH}>
  <!-- Hero Section -->
  <HeroSection
    eyebrow="PodCodar"
    title="Sobre nós"
    subtitle="Somos uma comunidade e organização sem fins lucrativos focada em transformar vidas por meio da educação profissionalizante em tecnologia — com inclusão, colaboração e qualidade de ensino."
    stats={[
      { icon: 'lucide:users', value: 'Comunidade', label: 'Inclusiva e acolhedora', color: 'blue' },
      { icon: 'lucide:graduation-cap', value: 'Educação', label: 'Profissionalizante', color: 'violet' },
      { icon: 'lucide:hand-heart', value: 'Impacto', label: 'Social e comunitário', color: 'emerald' },
    ]}
  >
    <Icon name="lucide:heart" slot="eyebrow-icon" class="w-4 h-4" />
  </HeroSection>

  <!-- Mission Section -->
  <section class="py-16 md:py-24 bg-base-100">
    <div class="mx-auto max-w-6xl px-4">
      <SectionHeader icon="lucide:target" title="Missão" subtitle="O que nos move" color="primary" class="mb-8" />

      <div class="max-w-3xl space-y-4">
        {mission.body.map((paragraph) => (
          <p class="text-base-content/90 m-0 text-lg leading-relaxed">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- Values Section -->
  <section class="py-16 md:py-24 bg-gradient-to-b from-base-200/50 to-base-100 border-y border-base-300/50">
    <div class="mx-auto max-w-6xl px-4">
      <SectionHeader
        icon="lucide:sparkles"
        title="Valores"
        subtitle="Três princípios que guiam a cultura da comunidade"
        color="violet"
        class="mb-12"
      />

      <ul class="grid gap-6 md:grid-cols-1 lg:grid-cols-3">
        {coreValues.map((value, index) => {
          const cards = [
            { from: 'from-blue-500/5', to: 'to-blue-600/10', border: 'hover:border-blue-500/30', gradient: 'from-blue-500 to-blue-600', icon: 'lucide:users' },
            { from: 'from-emerald-500/5', to: 'to-emerald-600/10', border: 'hover:border-emerald-500/30', gradient: 'from-emerald-500 to-emerald-600', icon: 'lucide:handshake' },
            { from: 'from-violet-500/5', to: 'to-violet-600/10', border: 'hover:border-violet-500/30', gradient: 'from-violet-500 to-violet-600', icon: 'lucide:award' },
          ];
          const c = cards[index];
          return (
            <li class="relative group grid">
              <div class={`absolute inset-0 bg-gradient-to-br ${c.from} ${c.to} rounded-2xl transform rotate-1 group-hover:rotate-2 transition-transform duration-300`}></div>
              <div class={`relative bg-base-100 rounded-2xl border border-base-300 p-6 ${c.border} hover:shadow-lg transition-all duration-300 grid grid-rows-[auto_auto_1fr]`}>
                <div class={`w-12 h-12 rounded-xl bg-gradient-to-br ${c.gradient} flex items-center justify-center mb-4`}>
                  <Icon name={c.icon} class="w-6 h-6 text-white" />
                </div>
                <h3 class="text-xl font-bold mb-2">{value.title}</h3>
                <p class="text-base-content/85 m-0 text-sm leading-relaxed">{value.text}</p>
              </div>
            </li>
          );
        })}
      </ul>
    </div>
  </section>

  <!-- Culture Section -->
  <section class="py-16 md:py-24 bg-base-100">
    <div class="mx-auto max-w-6xl px-4">
      <SectionHeader
        icon="lucide:building-2"
        title={aboutCommunity.title}
        subtitle={aboutCommunity.lead}
        color="emerald"
        class="mb-8"
      />

      <ul class="mb-0 max-w-3xl list-none space-y-4 pl-2">
        {aboutCommunity.points.map((point, index) => {
          const icons = ['lucide:book-marked', 'lucide:git-branch', 'lucide:rocket'];
          return (
            <li class="grid grid-cols-[auto_1fr] gap-4 items-start group">
              <div class="w-10 h-10 rounded-xl bg-emerald-500/10 flex items-center justify-center shrink-0 group-hover:bg-emerald-500/20 transition-colors duration-300">
                <Icon name={icons[index]} class="w-5 h-5 text-emerald-600" />
              </div>
              <span class="text-base-content/90 text-lg leading-relaxed pt-1">{point}</span>
            </li>
          );
        })}
      </ul>
    </div>
  </section>

  <!-- Communication Channels Section -->
  <section class="py-16 md:py-24 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-primary/5 via-base-100 to-secondary/5"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-primary/10 via-transparent to-transparent"></div>

    <div class="relative mx-auto max-w-6xl px-4">
      <SectionHeader
        icon="lucide:message-circle"
        title="Onde conversamos"
        subtitle="Cada canal tem um papel — escolha o ritmo que combina com você"
        color="blue"
        class="mb-8"
      />

      <ul class="grid gap-4 md:grid-cols-1 lg:grid-cols-3">
        {communicationChannels.map((ch) => (
          <ChannelCard icon={ch.icon} title={ch.channel} subtitle={ch.description} color={ch.color} />
        ))}
      </ul>
    </div>
  </section>

  <!-- Projects Section -->
  <section class="py-16 md:py-24 bg-base-100">
    <div class="mx-auto max-w-6xl px-4">
      <SectionHeader
        icon="lucide:folder-git-2"
        title="Projetos e repositórios"
        subtitle="A comunidade também constrói em código aberto — além das iniciativas dentro das guildas"
        color="violet"
        class="mb-8"
      />

      <ul class="grid gap-4 md:grid-cols-2 max-w-3xl">
        {projects.map((project) => (
          <li class="bg-base-100 rounded-2xl border border-base-300 p-6 hover:border-violet-500/30 hover:shadow-lg transition-all duration-300 grid grid-rows-[auto_1fr_auto]">
            <h3 class="text-xl font-semibold mb-2">{project.name}</h3>
            <p class="text-base-content/80 m-0 mb-4 text-sm leading-relaxed">{project.description}</p>
            <a
              href={project.href}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sm font-medium text-violet-600 hover:text-violet-700 no-underline"
            >
              <Icon name="lucide:external-link" class="w-4 h-4" />
              Abrir link
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Events CTA Section -->
  <CallToAction icon="lucide:calendar-days" title={eventsBlock.title} description={eventsBlock.body}>
    <a
      href={eventsBlock.externalHref}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-3 px-8 py-4 bg-primary text-primary-content rounded-xl font-semibold hover:bg-primary/90 hover:shadow-lg hover:shadow-primary/20 transition-all duration-300"
    >
      <Icon name="lucide:external-link" class="w-5 h-5" />
      {eventsBlock.externalLabel}
    </a>
  </CallToAction>
</Layout>
