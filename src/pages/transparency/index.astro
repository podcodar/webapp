---
import { getCollection } from 'astro:content';
import { Icon } from 'astro-icon/components';
import FormattedDate from '@/components/FormattedDate.astro';
import DocumentCard from '@/components/transparency/DocumentCard.astro';
import CallToAction from '@/components/ui/CallToAction.astro';
import HeroSection from '@/components/ui/HeroSection.astro';
import IconCard from '@/components/ui/IconCard.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import { BOARD_MEMBERS, CNPJ, CONTACT_EMAIL, METRICS } from '@/data/transparency';
import { useTranslations } from '@/i18n/utils';
import Layout from '@/layouts/Layout.astro';

const t = useTranslations();

const documents = (await getCollection('transparency')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const institutionalDocs = documents.filter((d) => d.data.category === 'institucional');
const financialDocs = documents.filter((d) => d.data.category === 'financeiro');
const fiscalDocs = documents.filter((d) => d.data.category === 'fiscal');

const lastUpdated = documents[0]?.data.date;
const formattedLastUpdated = lastUpdated?.toLocaleDateString('pt-br', {
  day: '2-digit',
  month: 'short',
  year: 'numeric',
});
---

<Layout
  title={t('transparency.title')}
  description={t('transparency.subtitle')}
  mainClass="flex flex-1 flex-col"
>
  <!-- Hero Section -->
  <HeroSection
    eyebrow={t('transparency.hero.eyebrow')}
    title={t('transparency.title')}
    subtitle={t('transparency.intro')}
    stats={[
      { icon: 'lucide:file-text', value: documents.length, label: t('transparency.hero.stats.documents'), color: 'blue' },
      { icon: 'lucide:users', value: BOARD_MEMBERS.length, label: t('transparency.hero.stats.members'), color: 'violet' },
      ...(lastUpdated && formattedLastUpdated ? [{ icon: 'lucide:calendar-check', value: formattedLastUpdated, label: t('transparency.lastUpdated'), color: 'emerald' as const }] : []),
    ]}
  >
    <Icon name="lucide:shield-check" slot="eyebrow-icon" class="w-4 h-4" />
  </HeroSection>

  <!-- Documents Section -->
  <section class="py-16 md:py-24 bg-base-100">
    <div class="mx-auto max-w-6xl px-4">
      <SectionHeader
        icon="lucide:folder-open"
        title={t('transparency.documents.title')}
        subtitle={t('transparency.documents.subtitle')}
        color="primary"
        class="mb-12"
      />

      {institutionalDocs.length > 0 && (
        <div class="mb-12">
          <h3 class="text-lg font-semibold mb-4 flex items-center gap-2 text-base-content/80">
            <span class="w-8 h-8 rounded-lg bg-blue-500/10 flex items-center justify-center">
              <Icon name="lucide:building-2" class="w-4 h-4 text-blue-500" />
            </span>
            {t('transparency.category.institucional')}
          </h3>
          <ul class="grid gap-5 md:grid-cols-2">
            {institutionalDocs.map((doc) => (
              <li>
                <DocumentCard doc={doc} href={`/transparency/${doc.id}/`} />
              </li>
            ))}
          </ul>
        </div>
      )}

      {financialDocs.length > 0 && (
        <div class="mb-12">
          <h3 class="text-lg font-semibold mb-4 flex items-center gap-2 text-base-content/80">
            <span class="w-8 h-8 rounded-lg bg-emerald-500/10 flex items-center justify-center">
              <Icon name="lucide:bar-chart-3" class="w-4 h-4 text-emerald-500" />
            </span>
            {t('transparency.category.financeiro')}
          </h3>
          <ul class="grid gap-5 md:grid-cols-2">
            {financialDocs.map((doc) => (
              <li>
                <DocumentCard doc={doc} href={`/transparency/${doc.id}/`} />
              </li>
            ))}
          </ul>
        </div>
      )}

      {fiscalDocs.length > 0 && (
        <div>
          <h3 class="text-lg font-semibold mb-4 flex items-center gap-2 text-base-content/80">
            <span class="w-8 h-8 rounded-lg bg-violet-500/10 flex items-center justify-center">
              <Icon name="lucide:shield-check" class="w-4 h-4 text-violet-500" />
            </span>
            {t('transparency.category.fiscal')}
          </h3>
          <ul class="grid gap-5 md:grid-cols-2">
            {fiscalDocs.map((doc) => (
              <li>
                <DocumentCard doc={doc} href={`/transparency/${doc.id}/`} />
              </li>
            ))}
          </ul>
        </div>
      )}
    </div>
  </section>

  <!-- Board Section -->
  <section class="py-16 md:py-24 bg-gradient-to-b from-base-200/50 to-base-100 border-y border-base-300/50">
    <div class="mx-auto max-w-6xl px-4">
      <SectionHeader
        icon="lucide:users"
        title={t('transparency.board.title')}
        subtitle={t('transparency.board.subtitle')}
        color="violet"
        class="mb-12"
      />

      <ul class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {BOARD_MEMBERS.map((member, index) => (
          <li class="group bg-base-100 rounded-xl border border-base-300 p-5 hover:border-violet-500/30 hover:shadow-lg hover:shadow-violet-500/5 transition-all duration-300 grid items-center">
            <div class="grid grid-cols-[auto_1fr] items-center gap-4">
              <div class="relative">
                <div class="w-14 h-14 rounded-full bg-gradient-to-br from-violet-500/20 to-violet-600/20 flex items-center justify-center text-violet-600 font-bold text-lg group-hover:scale-110 transition-transform duration-300">
                  {member.name.charAt(0)}
                </div>
                {index === 0 && (
                  <div class="absolute -top-1 -right-1 w-5 h-5 rounded-full bg-violet-500 flex items-center justify-center" title="Presidente">
                    <Icon name="lucide:crown" class="w-3 h-3 text-white" />
                  </div>
                )}
              </div>
              <div>
                <h3 class="font-semibold text-base group-hover:text-violet-600 transition-colors">{member.name}</h3>
                <p class="text-sm text-base-content/60">{member.role}</p>
              </div>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Metrics Section -->
  <section class="py-16 md:py-24 bg-base-100">
    <div class="mx-auto max-w-6xl px-4">
      <SectionHeader
        icon="lucide:trending-up"
        title={t('transparency.metrics.title')}
        subtitle={t('transparency.metrics.subtitle')}
        color="emerald"
        class="mb-12"
      />

      <ul class="grid gap-6 md:grid-cols-3">
        {METRICS.map((metric) => (
          <IconCard value={metric.value} label={metric.label} color="emerald" />
        ))}
      </ul>
    </div>
  </section>

  <!-- Contact Section -->
  <CallToAction icon="lucide:message-circle" title={t('transparency.contact.title')} description={t('transparency.contact.text')}>
    <a
      href={`mailto:${CONTACT_EMAIL}`}
      class="inline-flex items-center gap-3 px-8 py-4 bg-primary text-primary-content rounded-xl font-semibold hover:bg-primary/90 hover:shadow-lg hover:shadow-primary/20 transition-all duration-300"
    >
      <Icon name="lucide:mail" class="w-5 h-5" />
      {CONTACT_EMAIL}
    </a>

    <div slot="footer" class="mt-12 pt-8 border-t border-base-300/50">
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 text-sm text-base-content/60">
        <span class="flex items-center gap-2">
          <Icon name="lucide:building" class="w-4 h-4" />
          {t('transparency.cnpj')}: {CNPJ}
        </span>
        {lastUpdated && (
          <span class="flex items-center gap-2">
            <Icon name="lucide:refresh-cw" class="w-4 h-4" />
            {t('transparency.lastUpdated')}: <FormattedDate date={lastUpdated} />
          </span>
        )}
      </div>
    </div>
  </CallToAction>
</Layout>
