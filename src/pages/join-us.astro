---
import { Icon } from 'astro-icon/components';
import HeroSection from '@/components/ui/HeroSection.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import { LAYOUT_MAIN_FULL_WIDTH, SITE_TITLE } from '@/consts';
import { communicationChannels } from '@/data/marketing';
import ogDefaultImage from '@/data/og-default';
import Layout from '@/layouts/Layout.astro';

const title = `Faça parte — ${SITE_TITLE}`;
const description =
  'Entre na PodCodar: WhatsApp, Discord, Google Meet — e um plano de ação para começar a colaborar.';

const channelStats = communicationChannels.length;
---

<Layout {title} {description} image={ogDefaultImage} mainClass={LAYOUT_MAIN_FULL_WIDTH}>
  <!-- Hero Section -->
  <HeroSection
    eyebrow="Junte-se à comunidade"
    title="Faça parte"
    subtitle="Seja para aprender, ensinar ou colaborar com a comunidade, o caminho começa nos canais e nas guildas — espaços onde organizamos estudos, mentorias e projetos."
    stats={[
      { icon: 'lucide:message-square', value: channelStats, label: 'Canais principais', color: 'blue' },
      { icon: 'lucide:users', value: '300+', label: 'Membros ativos', color: 'violet' },
      { icon: 'lucide:calendar', value: 'Semanal', label: 'Encontros', color: 'emerald' },
    ]}
  />

  <!-- Channels Section -->
  <section class="py-16 md:py-24 bg-base-100">
    <div class="mx-auto max-w-6xl px-4">
      <SectionHeader
        icon="lucide:radio"
        title="Onde a comunidade vive"
        subtitle="Comunicação diária no WhatsApp; estudos e conteúdo no Discord; reuniões e eventos ao vivo no Meet."
        color="primary"
        class="mb-12"
      />

      <ul class="grid gap-5 md:grid-cols-3">
        {communicationChannels.map((ch, index) => {
          const colors = [
            { from: 'from-emerald-500/5', to: 'to-emerald-600/10', text: 'text-emerald-500', border: 'hover:border-emerald-500/30' },
            { from: 'from-violet-500/5', to: 'to-violet-600/10', text: 'text-violet-500', border: 'hover:border-violet-500/30' },
            { from: 'from-blue-500/5', to: 'to-blue-600/10', text: 'text-blue-500', border: 'hover:border-blue-500/30' },
          ];
          const c = colors[index % colors.length];
          const icons = ['lucide:message-circle', 'simple-icons:discord', 'lucide:video'];
          return (
            <li class="group relative">
              <div class={`absolute inset-0 bg-gradient-to-br ${c.from} to-${c.to} rounded-2xl transform rotate-1 group-hover:rotate-2 transition-transform duration-300`}></div>
              <div class={`relative bg-base-100 rounded-2xl border border-base-300 p-6 hover:${c.border} hover:shadow-lg transition-all duration-300`}>
                <div class={`w-12 h-12 rounded-xl bg-gradient-to-br ${c.from} ${c.text} flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300`}>
                  <Icon name={icons[index]} class="w-6 h-6" />
                </div>
                <h3 class="text-xl font-semibold mb-2 group-hover:text-primary transition-colors">{ch.channel}</h3>
                <p class="text-base-content/70 text-sm leading-relaxed">{ch.description}</p>
              </div>
            </li>
          );
        })}
      </ul>
    </div>
  </section>

  <!-- Steps Section -->
  <section class="py-16 md:py-24 bg-gradient-to-b from-base-200/50 to-base-100 border-y border-base-300/50">
    <div class="mx-auto max-w-6xl px-4">
      <SectionHeader
        icon="lucide:compass"
        title="Primeiros passos"
        subtitle="Sugestão de roteiro para quem está chegando — adapte ao seu tempo."
        color="violet"
        class="mb-12"
      />

      <ol class="max-w-3xl list-none space-y-6 pl-0">
        {[
          { step: '01', icon: 'lucide:compass', title: 'Imersão', desc: 'Entre nos grupos no WhatsApp e nos canais do Discord; leia as regras e se apresente.', color: 'violet' },
          { step: '02', icon: 'lucide:target', title: 'Escolha', desc: 'Participe das guildas e iniciativas que mais fazem sentido para você (projetos, eventos, design, etc.).', color: 'emerald' },
          { step: '03', icon: 'lucide:handshake', title: 'Engajamento', desc: 'Participe de grupos de estudo e de mentorias em projetos — como mentorado ou mentor.', color: 'blue' },
          { step: '04', icon: 'lucide:code-2', title: 'Colaboração', desc: 'Entre em discussões, junte-se a projetos e compartilhe o que está aprendendo.', color: 'primary' },
          { step: '05', icon: 'lucide:trending-up', title: 'Crescimento', desc: 'Peça feedback, peça sugestões de estudo e proponha ideias novas para as guildas.', color: 'violet' },
        ].map((item) => (
          <li class="group relative pl-16">
            <div class={`absolute left-0 top-0 w-12 h-12 rounded-xl bg-gradient-to-br from-${item.color}-500/10 to-${item.color}-500/20 flex items-center justify-center group-hover:scale-110 group-hover:from-${item.color}-500/20 transition-all duration-300`}>
              <Icon name={item.icon} class={`w-5 h-5 text-${item.color}-500`} />
            </div>
            <div class="absolute left-5 top-12 bottom-0 w-px bg-gradient-to-b from-base-300 to-transparent"></div>
            <div>
              <h3 class="text-lg font-semibold flex items-center gap-2">
                <span class={`text-${item.color}-500 font-mono text-sm`}>{item.step}</span>
                {item.title}
              </h3>
              <p class="text-base-content/70 text-sm leading-relaxed mt-1">{item.desc}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- GitHub Section -->
  <section class="py-16 md:py-24 bg-base-100">
    <div class="mx-auto max-w-6xl px-4">
      <div class="relative overflow-hidden rounded-2xl border border-base-300 bg-gradient-to-br from-base-100 to-base-200/50 p-8 md:p-12 group hover:border-primary/30 hover:shadow-lg hover:shadow-primary/5 transition-all duration-300">
        <div class="absolute -top-20 -right-20 w-64 h-64 bg-primary/5 rounded-full blur-3xl"></div>
        <div class="absolute -bottom-20 -left-20 w-64 h-64 bg-violet-500/5 rounded-full blur-3xl"></div>

        <div class="relative flex flex-col md:flex-row items-start md:items-center gap-6">
          <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-primary to-primary/70 flex items-center justify-center shadow-lg shadow-primary/20 group-hover:scale-110 transition-transform duration-300">
            <Icon name="lucide:github" class="w-8 h-8 text-primary-content" />
          </div>
          <div class="flex-1">
            <h2 class="text-2xl font-bold mb-2">GitHub</h2>
            <p class="text-base-content/70 mb-4">Código aberto, transparência e boas primeiras contribuições.</p>
            <a
              href="https://github.com/podcodar"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-primary font-medium hover:underline"
            >
              <span>Acessar github.com/podcodar</span>
              <Icon name="lucide:external-link" class="w-4 h-4" />
            </a>
          </div>
          <a
            href="https://github.com/podcodar"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-primary no-underline"
          >
            Ver repositórios
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="py-16 md:py-24 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-primary/5 via-base-100 to-secondary/5"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-primary/10 via-transparent to-transparent"></div>

    <div class="relative mx-auto max-w-6xl px-4">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-12">
          <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-primary to-primary/70 flex items-center justify-center shadow-lg shadow-primary/20 mx-auto mb-6">
            <Icon name="lucide:message-circle" class="w-8 h-8 text-primary-content" />
          </div>
          <SectionHeader
            icon="lucide:mail"
            title="Contato"
            subtitle="Prefere uma mensagem antes de entrar nos grupos? Entre em contato!"
            color="primary"
            class="justify-center mb-4"
          />
        </div>

        <div class="grid gap-6 md:grid-cols-2 mb-8">
          <a
            href="/contact"
            class="group relative p-6 bg-base-100 rounded-2xl border border-base-300 hover:border-primary/30 hover:shadow-lg hover:shadow-primary/5 transition-all duration-300 text-center"
          >
            <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform duration-300">
              <Icon name="lucide:send" class="w-6 h-6 text-primary" />
            </div>
            <h3 class="font-semibold mb-2">Envie uma mensagem</h3>
            <p class="text-sm text-base-content/60">Fale diretamente com a gente pelo formulário de contato.</p>
          </a>

          <a
            href="https://github.com/podcodar"
            target="_blank"
            rel="noopener noreferrer"
            class="group relative p-6 bg-base-100 rounded-2xl border border-base-300 hover:border-violet-500/30 hover:shadow-lg hover:shadow-violet-500/5 transition-all duration-300 text-center"
          >
            <div class="w-12 h-12 rounded-xl bg-violet-500/10 flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform duration-300">
              <Icon name="lucide:message-square" class="w-6 h-6 text-violet-500" />
            </div>
            <h3 class="font-semibold mb-2">Conversar no Discord</h3>
            <p class="text-sm text-base-content/60">Participe das discussões e conheça a comunidade.</p>
          </a>
        </div>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 text-base-content/60">
          <span class="flex items-center gap-2">
            <Icon name="lucide:zap" class="w-4 h-4 text-primary" />
            Resposta rápida
          </span>
          <span class="hidden sm:block">•</span>
          <span class="flex items-center gap-2">
            <Icon name="lucide:heart" class="w-4 h-4 text-emerald-500" />
            Comunidade acolhedora
          </span>
          <span class="hidden sm:block">•</span>
          <span class="flex items-center gap-2">
            <Icon name="lucide:shield" class="w-4 h-4 text-violet-500" />
            Espaço seguro
          </span>
        </div>
      </div>
    </div>
  </section>
</Layout>