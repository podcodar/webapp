---
import { Icon } from 'astro-icon/components';
import CallToAction from '@/components/ui/CallToAction.astro';
import ChannelCard from '@/components/ui/ChannelCard.astro';
import HeroSection from '@/components/ui/HeroSection.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import StepItem from '@/components/ui/StepItem.astro';
import { LAYOUT_MAIN_FULL_WIDTH, SITE_TITLE } from '@/consts';
import { DISCORD_INVITE_URL } from '@/data/community';
import { communicationChannels } from '@/data/marketing';

import { useTranslations } from '@/i18n/utils';
import Layout from '@/layouts/Layout.astro';

const t = useTranslations();
const title = `${t('nav.join_us')} - ${SITE_TITLE}`;
const description = t('joinUs.hero.subtitle');
---

<Layout {title} {description} mainClass={LAYOUT_MAIN_FULL_WIDTH}>
  <!-- Hero Section -->
  <HeroSection
    eyebrow={t('joinUs.hero.eyebrow')}
    title={t('joinUs.hero.title')}
    subtitle={t('joinUs.hero.subtitle')}
    stats={[
      { icon: 'lucide:message-square', value: communicationChannels.length, label: t('joinUs.hero.stats.channels'), color: 'blue' },
      { icon: 'lucide:users', value: '300+', label: t('joinUs.hero.stats.members'), color: 'violet' },
      { icon: 'lucide:calendar', value: 'Semanal', label: t('joinUs.hero.stats.meetups'), color: 'emerald' },
    ]}
  >
    <Icon name="lucide:heart-handshake" slot="eyebrow-icon" class="w-4 h-4" />
  </HeroSection>

  <!-- Channels Section -->
  <section class="py-16 md:py-24 bg-base-100">
    <div class="mx-auto max-w-6xl px-4">
      <SectionHeader
        icon="lucide:radio"
        title={t('joinUs.channels.title')}
        subtitle={t('joinUs.channels.subtitle')}
        color="primary"
        class="mb-8"
      />

      <ul class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {communicationChannels.map((ch) => (
          <ChannelCard icon={ch.icon} title={t(ch.nameKey)} subtitle={t(ch.descKey)} color={ch.color} />
        ))}
      </ul>
    </div>
  </section>

  <!-- Steps Section -->
  <section class="py-16 md:py-24 bg-gradient-to-b from-base-200/50 to-base-100 border-y border-base-300/50">
    <div class="mx-auto max-w-6xl px-4">
      <SectionHeader
        icon="lucide:compass"
        title={t('joinUs.steps.title')}
        subtitle={t('joinUs.steps.subtitle')}
        color="violet"
        class="mb-8"
      />

      <ol class="max-w-3xl list-none space-y-6 pl-0">
        <StepItem step="01" icon="lucide:compass" title={t('joinUs.steps.s1.title')} desc={t('joinUs.steps.s1.desc')} color="violet" />
        <StepItem step="02" icon="lucide:target" title={t('joinUs.steps.s2.title')} desc={t('joinUs.steps.s2.desc')} color="emerald" />
        <StepItem step="03" icon="lucide:handshake" title={t('joinUs.steps.s3.title')} desc={t('joinUs.steps.s3.desc')} color="blue" />
        <StepItem step="04" icon="lucide:code-2" title={t('joinUs.steps.s4.title')} desc={t('joinUs.steps.s4.desc')} color="primary" />
        <StepItem step="05" icon="lucide:trending-up" title={t('joinUs.steps.s5.title')} desc={t('joinUs.steps.s5.desc')} color="violet" />
      </ol>
    </div>
  </section>

  <!-- GitHub Section -->
  <section class="py-16 md:py-24 bg-base-100">
    <div class="mx-auto max-w-6xl px-4">
      <SectionHeader
        icon="lucide:github"
        title={t('joinUs.github.title')}
        subtitle={t('joinUs.github.desc')}
        color="emerald"
        class="mb-8"
      />

      <div class="max-w-3xl">
        <p class="text-base-content/90 m-0 mb-6 text-lg leading-relaxed">
          {t('joinUs.github.body')}
        </p>
        <p class="m-0 flex flex-wrap gap-3">
          <a
            href="https://github.com/podcodar"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-primary no-underline"
          >
            <Icon name="lucide:external-link" class="w-4 h-4" />
            {t('joinUs.github.cta')}
          </a>
          <a href="/contributing" class="btn btn-outline btn-primary no-underline">
            {t('joinUs.github.contributingLink')}
          </a>
        </p>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <CallToAction icon="lucide:send" title={t('joinUs.cta.title')} description={t('joinUs.cta.description')}>
    <a
      href="/contact"
      class="inline-flex items-center gap-3 px-8 py-4 bg-primary text-primary-content rounded-xl font-semibold hover:bg-primary/90 hover:shadow-lg hover:shadow-primary/20 transition-all duration-300"
    >
      <Icon name="lucide:mail" class="w-5 h-5" />
      {t('joinUs.cta.button')}
    </a>
    <a
      href={DISCORD_INVITE_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-3 px-8 py-4 bg-violet-500/10 text-violet-600 rounded-xl font-semibold hover:bg-violet-500/20 hover:shadow-lg hover:shadow-violet-500/10 transition-all duration-300 border border-violet-500/20"
    >
      <Icon name="lucide:message-circle" class="w-5 h-5" />
      {t('joinUs.cta.discord')}
    </a>
  </CallToAction>
</Layout>
