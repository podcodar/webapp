---
import { Icon } from 'astro-icon/components';
import { socialIconify, socialLinks } from '@/data/social-links';
import { CONTACT_EMAIL } from '@/data/transparency';
import { useTranslations } from '@/i18n/utils';
import Layout from '@/layouts/Layout.astro';

const t = useTranslations('pt-br');
---

<Layout title={`${t('nav.contact')} | PodCodar`} description={t('contact.subtitle')} mainClass="flex flex-1 flex-col">
  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-gradient-to-br from-primary/5 via-base-100 to-base-100 border-b border-base-300/50">
    <!-- Background decoration -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute -top-40 -right-40 w-96 h-96 bg-primary/5 rounded-full blur-3xl"></div>
      <div class="absolute -bottom-40 -left-40 w-96 h-96 bg-secondary/5 rounded-full blur-3xl"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-gradient-to-r from-primary/3 to-secondary/3 rounded-full blur-3xl"></div>
    </div>

    <div class="relative mx-auto max-w-6xl px-4 py-24 md:py-32">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-primary/10 text-primary text-sm font-medium mb-6">
        <Icon name="lucide:rocket" class="w-4 h-4" />
        <span>{t('contact.eyebrow')}</span>
      </div>

      <h1 class="text-5xl md:text-6xl font-bold tracking-tight mb-6 bg-gradient-to-r from-base-content via-base-content to-base-content/70 bg-clip-text">
        {t('contact.title')}
      </h1>

      <p class="text-xl text-base-content/70 max-w-2xl leading-relaxed">
        {t('contact.intro')}
      </p>

      <!-- Response stats -->
      <div class="flex flex-wrap gap-6 mt-10">
        <div class="flex items-center gap-3">
          <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center">
            <Icon name="lucide:zap" class="w-6 h-6 text-primary" />
          </div>
          <div>
            <span class="block text-lg font-bold">{t('response.fast')}</span>
            <span class="text-sm text-base-content/60">{t('response.fast.desc')}</span>
          </div>
        </div>
        <div class="flex items-center gap-3">
          <div class="w-12 h-12 rounded-xl bg-violet-500/10 flex items-center justify-center">
            <Icon name="lucide:users" class="w-6 h-6 text-violet-500" />
          </div>
          <div>
            <span class="block text-lg font-bold">{t('response.community')}</span>
            <span class="text-sm text-base-content/60">{t('response.community.desc')}</span>
          </div>
        </div>
        <div class="flex items-center gap-3">
          <div class="w-12 h-12 rounded-xl bg-emerald-500/10 flex items-center justify-center">
            <Icon name="lucide:headphones" class="w-6 h-6 text-emerald-500" />
          </div>
          <div>
            <span class="block text-lg font-bold">{t('response.support')}</span>
            <span class="text-sm text-base-content/60">{t('response.support.desc')}</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Methods Section -->
  <section class="py-16 md:py-24 bg-base-100">
    <div class="mx-auto max-w-6xl px-4">
      <div class="flex items-center gap-4 mb-12">
        <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-primary to-primary/70 flex items-center justify-center shadow-lg shadow-primary/20">
          <Icon name="lucide:mail" class="w-7 h-7 text-primary-content" />
        </div>
        <div>
          <h2 class="text-3xl font-bold">{t('contact.methods.title')}</h2>
          <p class="text-base-content/60">{t('contact.methods.subtitle')}</p>
        </div>
      </div>

      <ul class="grid gap-6 md:grid-cols-3">
        <li>
          <a href={`mailto:${CONTACT_EMAIL}`} class="group block p-6 rounded-2xl border border-primary/20 bg-base-100 transition-all duration-300 hover:shadow-lg hover:border-primary/40">
            <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
              <Icon name="lucide:mail" class="w-6 h-6 text-primary" />
            </div>
            <span class="block text-sm text-base-content/60 mb-1">{t('contact.email.label')}</span>
            <span class="block text-lg font-semibold group-hover:text-primary transition-colors">{CONTACT_EMAIL}</span>
          </a>
        </li>
        <li>
          <a href="#" class="group block p-6 rounded-2xl border border-violet-500/20 bg-base-100 transition-all duration-300 hover:shadow-lg hover:border-violet-500/40">
            <div class="w-12 h-12 rounded-xl bg-violet-500/10 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
              <Icon name="lucide:message-circle" class="w-6 h-6 text-violet-500" />
            </div>
            <span class="block text-sm text-base-content/60 mb-1">Discord</span>
            <span class="block text-lg font-semibold group-hover:text-primary transition-colors">Comunidade Discord</span>
          </a>
        </li>
        <li>
          <a href="#" class="group block p-6 rounded-2xl border border-emerald-500/20 bg-base-100 transition-all duration-300 hover:shadow-lg hover:border-emerald-500/40">
            <div class="w-12 h-12 rounded-xl bg-emerald-500/10 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
              <Icon name="lucide:calendar" class="w-6 h-6 text-emerald-500" />
            </div>
            <span class="block text-sm text-base-content/60 mb-1">Eventos</span>
            <span class="block text-lg font-semibold group-hover:text-primary transition-colors">Participe de eventos</span>
          </a>
        </li>
      </ul>
    </div>
  </section>

  <!-- Types of Inquiries Section -->
  <section class="py-16 md:py-24 bg-gradient-to-b from-base-200/50 to-base-100 border-y border-base-300/50">
    <div class="mx-auto max-w-6xl px-4">
      <div class="flex items-center gap-4 mb-12">
        <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-violet-500 to-violet-600 flex items-center justify-center shadow-lg shadow-violet-500/20">
          <Icon name="lucide:help-circle" class="w-7 h-7 text-white" />
        </div>
        <div>
          <h2 class="text-3xl font-bold">{t('contact.inquiries.title')}</h2>
          <p class="text-base-content/60">{t('contact.inquiries.subtitle')}</p>
        </div>
      </div>

      <ul class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        <li class="group">
          <div class="h-full p-6 rounded-xl border bg-blue-500/5 border-blue-500/20 transition-all duration-300 group-hover:shadow-lg">
            <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-blue-500 to-blue-600 flex items-center justify-center mb-3 group-hover:scale-110 transition-transform duration-300">
              <Icon name="lucide:graduation-cap" class="w-5 h-5 text-white" />
            </div>
            <h3 class="font-semibold mb-1">{t('contact.inquiries.mentorship.title')}</h3>
            <p class="text-sm text-base-content/60">{t('contact.inquiries.mentorship.desc')}</p>
          </div>
        </li>
        <li class="group">
          <div class="h-full p-6 rounded-xl border bg-violet-500/5 border-violet-500/20 transition-all duration-300 group-hover:shadow-lg">
            <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-violet-500 to-violet-600 flex items-center justify-center mb-3 group-hover:scale-110 transition-transform duration-300">
              <Icon name="lucide:handshake" class="w-5 h-5 text-white" />
            </div>
            <h3 class="font-semibold mb-1">{t('contact.inquiries.partnerships.title')}</h3>
            <p class="text-sm text-base-content/60">{t('contact.inquiries.partnerships.desc')}</p>
          </div>
        </li>
        <li class="group">
          <div class="h-full p-6 rounded-xl border bg-primary/5 border-primary/20 transition-all duration-300 group-hover:shadow-lg">
            <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-primary to-primary/70 flex items-center justify-center mb-3 group-hover:scale-110 transition-transform duration-300">
              <Icon name="lucide:heart" class="w-5 h-5 text-white" />
            </div>
            <h3 class="font-semibold mb-1">{t('contact.inquiries.volunteer.title')}</h3>
            <p class="text-sm text-base-content/60">{t('contact.inquiries.volunteer.desc')}</p>
          </div>
        </li>
        <li class="group">
          <div class="h-full p-6 rounded-xl border bg-emerald-500/5 border-emerald-500/20 transition-all duration-300 group-hover:shadow-lg">
            <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-emerald-500 to-emerald-600 flex items-center justify-center mb-3 group-hover:scale-110 transition-transform duration-300">
              <Icon name="lucide:heart" class="w-5 h-5 text-white" />
            </div>
            <h3 class="font-semibold mb-1">{t('contact.inquiries.donations.title')}</h3>
            <p class="text-sm text-base-content/60">{t('contact.inquiries.donations.desc')}</p>
          </div>
        </li>
        <li class="group">
          <div class="h-full p-6 rounded-xl border bg-blue-500/5 border-blue-500/20 transition-all duration-300 group-hover:shadow-lg">
            <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-blue-500 to-blue-600 flex items-center justify-center mb-3 group-hover:scale-110 transition-transform duration-300">
              <Icon name="lucide:help-circle" class="w-5 h-5 text-white" />
            </div>
            <h3 class="font-semibold mb-1">{t('contact.inquiries.general.title')}</h3>
            <p class="text-sm text-base-content/60">{t('contact.inquiries.general.desc')}</p>
          </div>
        </li>
      </ul>
    </div>
  </section>

  <!-- Social Links Section -->
  <section class="py-16 md:py-24 bg-base-100">
    <div class="mx-auto max-w-6xl px-4">
      <div class="flex items-center gap-4 mb-12">
        <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-blue-500 to-blue-600 flex items-center justify-center shadow-lg shadow-blue-500/20">
          <Icon name="lucide:share-2" class="w-7 h-7 text-white" />
        </div>
        <div>
          <h2 class="text-3xl font-bold">{t('contact.social.title')}</h2>
          <p class="text-base-content/60">{t('contact.social.subtitle')}</p>
        </div>
      </div>

      <ul class="flex flex-wrap gap-4">
        {socialLinks.map((link) => (
          <li>
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-3 px-6 py-3 rounded-xl border border-base-300 bg-base-100 hover:border-primary/40 hover:shadow-lg hover:shadow-primary/5 transition-all duration-300"
              aria-label={link.label}
            >
              <Icon name={socialIconify[link.network]} class="w-5 h-5" />
              <span class="font-medium">{link.label}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 md:py-24 relative overflow-hidden">
    <!-- Background -->
    <div class="absolute inset-0 bg-gradient-to-br from-primary/5 via-base-100 to-secondary/5"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-primary/10 via-transparent to-transparent"></div>

    <div class="relative mx-auto max-w-6xl px-4">
      <div class="max-w-2xl mx-auto text-center">
        <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-primary to-primary/70 flex items-center justify-center shadow-lg shadow-primary/20 mx-auto mb-6">
          <Icon name="lucide:send" class="w-8 h-8 text-primary-content" />
        </div>
        <h2 class="text-3xl font-bold mb-4">{t('contact.cta.title')}</h2>
        <p class="text-lg text-base-content/70 mb-8">{t('contact.cta.text')}</p>

        <a
          href={`mailto:${CONTACT_EMAIL}`}
          class="inline-flex items-center gap-3 px-8 py-4 bg-primary text-primary-content rounded-xl font-semibold hover:bg-primary/90 hover:shadow-lg hover:shadow-primary/20 transition-all duration-300"
        >
          <Icon name="lucide:mail" class="w-5 h-5" />
          {t('contact.cta.button')}
        </a>
      </div>
    </div>
  </section>
</Layout>