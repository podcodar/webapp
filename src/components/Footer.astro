---
import { Icon } from 'astro-icon/components';
import Logo from '@/components/Logo.astro';
import SocialLinks from '@/components/SocialLinks.astro';
import { CNPJ } from '@/data/transparency';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';

const today = new Date();
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<footer class="border-t border-base-300 bg-base-200/90 px-4 py-12 text-center text-base-content/70">
  <div class="mb-6 flex justify-center">
    <Logo size="sm" showTitle class="justify-center" />
  </div>
  <p class="m-0">&copy; {today.getFullYear()} PodCodar. {t('footer.copyright')}</p>

  <div class="flex items-center justify-center gap-4 text-sm text-base-content/60">
    <span class="flex items-center gap-2">
      <Icon name="lucide:building" class="w-4 h-4" />
      {t('transparency.cnpj')}: {CNPJ}
    </span>
  </div>

  <SocialLinks />
</footer>
