---
import Logo from '@/components/Logo.astro';
import SocialLinks from '@/components/SocialLinks.astro';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';

const today = new Date();
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<footer class="border-t border-base-300 bg-base-200/90 px-4 py-12 text-center text-base-content/70">
  <div class="mb-6 flex justify-center">
    <Logo size="sm" showTitle class="justify-center" />
  </div>
  <p class="m-0">&copy; {today.getFullYear()} PodCodar. {t('footer.copyright')}</p>
  <SocialLinks />
</footer>
