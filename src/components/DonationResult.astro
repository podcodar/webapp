---
/**
 * DonationResult.astro — htmx-powered result pane.
 *
 * Listens for the "amount-valid" custom event dispatched by DonationForm,
 * then fetches /api/pix-result?amount=X via htmx and swaps the content.
 * Shows a loading skeleton during fetch and handles errors.
 * Alpine re-initializes swapped content via htmx:afterSwap hook.
 */
import { useTranslations } from '@/i18n/utils';

const t = useTranslations();
---

<div
  id="donation-result"
  class="donation-result-container"
  hx-get="/api/pix-result"
  hx-trigger="amount-valid from:body"
  hx-target="#donation-result"
  hx-swap="innerHTML"
  hx-include="#donation-amount"
  hx-indicator="#donation-loading"
>
  <!-- Loading skeleton (hidden by default, shown by htmx during request) -->
  <div id="donation-loading" class="htmx-indicator space-y-5">
    <div class="flex justify-center">
      <div class="bg-base-200 animate-pulse rounded-2xl w-56 h-56"></div>
    </div>
    <div class="space-y-3">
      <div class="bg-base-200 animate-pulse rounded h-4 w-28"></div>
      <div class="bg-base-300/50 animate-pulse rounded-xl h-24"></div>
      <div class="bg-base-200 animate-pulse rounded-lg h-12"></div>
    </div>
    <div class="flex justify-center">
      <div class="bg-base-200 animate-pulse rounded h-4 w-40"></div>
    </div>
  </div>

  <!-- Initial placeholder (visible before first selection) -->
  <div id="donation-placeholder" class="text-center py-8">
    <div class="text-base-content/40 text-6xl mb-4">💜</div>
    <p class="text-base-content/50 text-sm m-0">
      {t("contributing.donations.pix.loading")}
    </p>
  </div>
</div>

<script is:inline>
  // Alpine is set globally by Layout. Wait for it, then wire htmx hooks.
  function registerHtmxHooks() {
    var Alpine = window.Alpine;
    if (!Alpine) return;

    // Re-initialize Alpine in htmx-swapped content (api/pix-result HTML)
    document.body.addEventListener('htmx:afterSwap', function (e) {
      var target = e.detail && e.detail.target;
      if (!target || target.id !== 'donation-result') return;
      Alpine.destroyTree(target);
      Alpine.initTree(target);
    });

    // Clean up before swap to prevent Alpine instance leaks
    document.body.addEventListener('htmx:beforeSwap', function (e) {
      var target = e.detail && e.detail.target;
      if (!target || target.id !== 'donation-result') return;
      Alpine.destroyTree(target);
    });

    // Handle 400 errors from /api/pix-result
    document.body.addEventListener('htmx:responseError', function (e) {
      var target = e.detail && e.detail.target;
      if (!target || target.id !== 'donation-result') return;
      try {
        var body = JSON.parse(e.detail.xhr.responseText);
        if (body.error) {
          target.innerHTML = '<div class="alert alert-error text-sm" role="alert"><svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-5 w-5" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg><span>' + body.error + '</span></div>';
        }
      } catch (_) {
        target.innerHTML = '<p class="text-error text-sm m-0">Erro ao gerar QR code. Tente novamente.</p>';
      }
    });
  }

  if (window.Alpine) {
    registerHtmxHooks();
  } else {
    document.addEventListener('alpine:init', registerHtmxHooks, { once: true });
  }
</script>

<style>
  .htmx-indicator { opacity: 0; transition: opacity 200ms ease-in; }
  .htmx-request .htmx-indicator { opacity: 1; }
  .htmx-request #donation-placeholder { display: none; }

  :global([data-theme="podcodar-dark"]) .donation-result-container img {
    background: white;
    border-radius: 1rem;
    padding: 0.5rem;
  }

  [x-cloak] { display: none !important; }
</style>
