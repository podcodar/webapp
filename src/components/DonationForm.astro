---
/**
 * DonationForm.astro — Alpine.js donation amount selector.
 *
 * Renders suggested amount buttons + custom input with client-side validation.
 * Dispatches "amount-valid" custom event for htmx result pane integration.
 */
import { useTranslations } from '@/i18n/utils';

const t = useTranslations();
---

<div class="donation-form space-y-5" x-data="donationForm">
  <!-- Suggested amount buttons -->
  <div class="flex flex-wrap gap-3" role="group" aria-label="Valores sugeridos de doação">
    <button
      type="button"
      class="btn btn-lg flex-1 min-w-[100px]"
      :class="amount === 25 ? 'btn-primary' : 'btn-outline btn-primary'"
      @click="setAmount(25)"
      :aria-pressed="amount === 25"
    >
      {t("contributing.donations.pix.amount_25")}
    </button>
    <button
      type="button"
      class="btn btn-lg flex-1 min-w-[100px]"
      :class="amount === 50 ? 'btn-primary' : 'btn-outline btn-primary'"
      @click="setAmount(50)"
      :aria-pressed="amount === 50"
    >
      {t("contributing.donations.pix.amount_50")}
    </button>
    <button
      type="button"
      class="btn btn-lg flex-1 min-w-[100px]"
      :class="amount === 100 ? 'btn-primary' : 'btn-outline btn-primary'"
      @click="setAmount(100)"
      :aria-pressed="amount === 100"
    >
      {t("contributing.donations.pix.amount_100")}
    </button>
  </div>

  <!-- Custom amount input -->
  <div class="form-control w-full max-w-sm">
    <label class="label" for="donation-custom-amount">
      <span class="label-text font-medium">{t("contributing.donations.pix.custom_label")}</span>
    </label>
    <label class="input input-bordered flex items-center gap-2" for="donation-custom-amount">
      <span class="text-base-content/50 font-medium">R$</span>
      <input
        id="donation-custom-amount"
        type="text"
        inputmode="decimal"
        class="grow"
        x-model="customRaw"
        @input="validate(customRaw)"
        placeholder={t("contributing.donations.pix.custom_placeholder")}
        autocomplete="off"
      />
    </label>
  </div>

  <!-- Validation error (below minimum or invalid format) -->
  <div
    x-show="errorMessage !== '' && !largeDonation"
    x-cloak
    class="alert alert-error text-sm"
    role="alert"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-5 w-5" fill="none" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" />
    </svg>
    <span x-text="errorMessage"></span>
  </div>

  <!-- Large donation message (> R$ 10.000) -->
  <div
    x-show="largeDonation"
    x-cloak
    class="alert alert-info text-sm border border-info/20 bg-info/10"
    role="status"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-5 w-5" fill="none" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>
    <div>
      <p class="font-semibold m-0">{t("contributing.donations.pix.large_donation.title")}</p>
      <p class="m-0 mt-1">{t("contributing.donations.pix.large_donation.message")}</p>
      <a href="/contact" class="link link-info font-medium mt-1 inline-block">
        {t("contributing.donations.pix.large_donation.link")} →
      </a>
    </div>
  </div>

  <!-- Hidden input for htmx -->
  <input type="hidden" name="amount" id="donation-amount" :value="amount" />
</div>

<script define:vars={{
  invalidFormatMsg: t("contributing.donations.pix.validation.invalid_format"),
  belowMinimumMsg: t("contributing.donations.pix.validation.below_minimum"),
}}>
  document.addEventListener("alpine:init", () => {
    (window as any).Alpine.data("donationForm", () => ({
      amount: null as number | null,
      customRaw: "",
      errorMessage: "",
      largeDonation: false,

      validate(raw: string) {
        this.largeDonation = false;
        this.errorMessage = "";

        if (!raw.trim()) {
          this.amount = null;
          return;
        }

        if (!/^\d+(\.\d{1,2})?$/.test(raw.trim())) {
          this.errorMessage = invalidFormatMsg;
          this.amount = null;
          return;
        }

        const val = parseFloat(raw);
        if (val < 5) {
          this.errorMessage = belowMinimumMsg;
          this.amount = null;
          return;
        }

        if (val > 10000) {
          this.largeDonation = true;
          this.amount = null;
          return;
        }

        this.amount = val;
        this.$dispatch("amount-valid", { amount: val });
      },

      setAmount(val: number) {
        this.amount = val;
        this.customRaw = val.toString();
        this.errorMessage = "";
        this.largeDonation = false;
        this.$dispatch("amount-valid", { amount: val });
      },
    }));
  });
</script>
