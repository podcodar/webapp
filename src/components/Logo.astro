---
import { SITE_TITLE } from '../consts';

interface Props {
	/** Logo mark size */
	size?: 'sm' | 'md' | 'lg';
	/** Show site title next to the mark */
	showTitle?: boolean;
	class?: string;
}

const { size = 'md', showTitle = true, class: className } = Astro.props;

const logoSrc = `${import.meta.env.BASE_URL}images/logo.svg`;

const markClass =
	size === 'sm'
		? 'h-8 w-8 min-h-8 min-w-8'
		: size === 'lg'
			? 'h-14 w-14 min-h-14 min-w-14'
			: 'h-10 w-10 min-h-10 min-w-10';
---

<a
	href={import.meta.env.BASE_URL}
	class:list={[
		'flex items-center gap-2 no-underline transition-opacity hover:opacity-90',
		className,
	]}
>
	<img
		src={logoSrc}
		alt="PodCodar"
		width="300"
		height="300"
		class:list={[markClass, 'object-contain']}
		loading="eager"
		decoding="async"
	/>
	{
		showTitle && (
			<span class="text-lg font-semibold text-base-content">{SITE_TITLE}</span>
		)
	}
</a>
