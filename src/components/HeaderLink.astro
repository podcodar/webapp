---
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'a'>;

const { href, class: className, ...props } = Astro.props;
const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, '').replace(/\/$/, '') || '/';
const hrefNormalized = href.replace(/\/$/, '') || '/';
const subpath = pathname.match(/[^/]+/g);
const isActive = hrefNormalized === pathname || hrefNormalized === `/${subpath?.[0] ?? ''}`;
---

<a
  href={href}
  class:list={[
    'inline-block border-b-4 px-2 py-4 text-sm font-medium no-underline transition-colors',
    isActive
      ? 'border-primary text-primary'
      : 'border-transparent text-base-content hover:text-primary',
    className,
  ]}
  {...props}
>
  <slot />
</a>
