---
import type { ImageMetadata } from 'astro';
import BaseHead from '@/components/BaseHead.astro';
import Footer from '@/components/Footer.astro';
import Header from '@/components/Header.astro';
import { getLangFromUrl } from '@/i18n/utils';

interface Props {
	title: string;
	description: string;
	image?: ImageMetadata;
	/** Tailwind classes for `<main>` (width, padding, etc.) */
	mainClass?: string;
	/** Atributo `lang` do documento; padrão: locale do site (pt-BR). */
	lang?: string;
}

const {
	title,
	description,
	image,
	mainClass = 'mx-auto w-full max-w-[720px] flex-1 px-4 py-36',
	lang: langOverride,
} = Astro.props;

const rawLang = langOverride ?? getLangFromUrl(Astro.url);
const documentLang = rawLang === 'pt-br' ? 'pt-BR' : rawLang;
---

<!doctype html>
<html lang={documentLang}>
	<head>
		<BaseHead title={title} description={description} image={image} />
	</head>
	<body class="flex min-h-screen flex-col">
		<Header />
		<main class={mainClass}>
			<slot />
		</main>
		<Footer />
	</body>
</html>
